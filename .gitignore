# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# Environment variables and secrets
.env
.env.*
.streamlit/secrets.toml

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Data files
# Los datasets no se suben al repositorio por defecto.
# Se documentarán en README.md y, si hace falta, se enlazarán desde fuentes externas.
data/raw/*
!data/raw/.gitkeep

data/interim/*
!data/interim/.gitkeep

data/processed/*
!data/processed/.gitkeep
!data/processed/job_postings_enriched.csv
!data/processed/ine_salary_context_processed.csv
!data/processed/manfred_salary_reference_processed.csv

# Logs
*.log

# Streamlit configuration
.streamlit/*
!.streamlit/
!.streamlit/config.toml
.streamlit/secrets.toml
