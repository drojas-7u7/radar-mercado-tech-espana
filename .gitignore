# Data files
# Los datasets no se suben al repositorio por defecto.
# Se documentarán en README.md y, si hace falta, se enlazarán desde fuentes externas.
data/raw/*
!data/raw/.gitkeep

data/interim/*
!data/interim/.gitkeep

data/processed/*
!data/processed/.gitkeep

# Logs
*.log

# Streamlit cache
.streamlit/
